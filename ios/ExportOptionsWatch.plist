<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Re-sign the standalone iDrizzleWatch app for App Store distribution and
		 write the IPA to disk. destination=export (not upload) avoids Xcode's
		 IDEDistribution upload pipeline, which fails for watch-only archives
		 ("method not offering app-store-connect"). The resulting distribution-
		 signed IPA is uploaded separately with altool. -->
	<key>method</key>
	<string>app-store-connect</string>
	<key>destination</key>
	<string>export</string>
	<key>signingStyle</key>
	<string>automatic</string>
	<key>teamID</key>
	<string>__TEAM_ID__</string>
	<key>uploadSymbols</key>
	<true/>
	<key>manageAppVersionAndBuildNumber</key>
	<false/>
</dict>
</plist>
